# Copy to .env:  cp .env.example .env
#
# The key is read when the container STARTS (runtime), via --env-file or compose .env.

PORT=8000
HOST=0.0.0.0

CHROMA_DB_PATH=./chroma_db

# Groq (Llama chat for RAG answers) — https://console.groq.com/
# Embeddings run locally via Chroma (all-MiniLM-L6-v2) — no API key required.
GROQ_API_KEY=

# Docker: CHROMA_DB_PATH=/app/chroma_db
